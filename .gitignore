*.ipr
*.iws

# OS generated
.DS_Store
Thumbs.db

# Gradle
.gradle/

# Unity Addressables
Assets/AddressableAssetsData/*/*.bin*

# Android builds
*.apk
*.aab

# Crash reports
sysinfo.txt

# Keep important Unity folders
!/[Aa]ssets/
!/[Pp]ackages/
!/[Pp]rojectSettings/

# Keep meta files
!*.meta
