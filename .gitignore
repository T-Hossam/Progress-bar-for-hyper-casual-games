[Ll]ogs/
[Mm]emoryCaptures/
UserSettings/

# Asset meta data
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# IDEs
.vscode/
.idea/
.vs/

# Visual Studio / Rider
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
